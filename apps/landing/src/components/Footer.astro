---
interface Props {
  lang: "pl" | "en";
}
const { lang } = Astro.props;

const t = {
  pl: {
    tagline: "Napisy, które naprawdę rozumieją.",
    rights: "Wszelkie prawa zastrzeżone.",
    contact: "Kontakt",
  },
  en: {
    tagline: "Subtitles that actually understand.",
    rights: "All rights reserved.",
    contact: "Contact",
  },
}[lang];

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] px-6 py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 text-sm text-[var(--color-fg-muted)] sm:flex-row">
    <div class="flex items-center gap-2">
      <span class="inline-block h-4 w-4 rounded bg-[var(--color-accent)]"></span>
      <span class="font-medium text-[var(--color-fg)]">Vocra</span>
      <span>· {t.tagline}</span>
    </div>

    <div class="flex items-center gap-4">
      <a href="mailto:hello@vocra.dev" class="hover:text-[var(--color-fg)]">{t.contact}</a>
      <span>© {year} Vocra. {t.rights}</span>
    </div>
  </div>
</footer>
