---
interface Props {
  lang: "pl" | "en";
}
const { lang } = Astro.props;

const t = {
  pl: {
    contact: "Kontakt",
    note: "Wczesna wersja demo. Tłumaczenia mogą być niedoskonałe.",
  },
  en: {
    contact: "Contact",
    note: "Early demo build. Translations may be imperfect.",
  },
}[lang];

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg-soft)] px-6 py-10 text-sm text-[var(--color-fg-muted)]">
  <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 md:flex-row md:items-center">
    <div class="flex items-center gap-2">
      <span class="inline-block h-4 w-4 rounded bg-[var(--color-accent)]"></span>
      <span>© {year} Vocra</span>
    </div>
    <p class="max-w-md text-xs">{t.note}</p>
    <a href="mailto:hello@vocra.dev" class="hover:text-[var(--color-fg)]">{t.contact}: hello@vocra.dev</a>
  </div>
</footer>
