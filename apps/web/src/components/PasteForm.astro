---
interface Props {
  lang: "pl" | "en";
}
const { lang } = Astro.props;

const t = {
  pl: {
    badge: "Demo · bez instalacji",
    h1: "Wklej link YouTube. Oglądaj po polsku.",
    sub: "Wczesna wersja Vocra. Działa bez rozszerzenia — w przeglądarce.",
    placeholder: "https://www.youtube.com/watch?v=...",
    targetLabel: "Język napisów",
    targetPl: "Polski",
    targetEn: "Angielski",
    cta: "Włącz napisy",
    examples: "Spróbuj:",
    note: "Działa najlepiej z filmami, które mają napisy w oryginalnym języku.",
    invalid: "Nieprawidłowy link YouTube.",
  },
  en: {
    badge: "Demo · no install",
    h1: "Paste a YouTube link. Watch in your language.",
    sub: "Early Vocra build. No extension required — runs in your browser.",
    placeholder: "https://www.youtube.com/watch?v=...",
    targetLabel: "Subtitle language",
    targetPl: "Polish",
    targetEn: "English",
    cta: "Turn on subtitles",
    examples: "Try:",
    note: "Works best with videos that have captions in the original language.",
    invalid: "Invalid YouTube link.",
  },
}[lang];

const watchPath = lang === "pl" ? "/watch" : "/en/watch";
const defaultTarget = lang === "pl" ? "pl" : "en";
const examples: { label: string; videoID: string }[] = [
  { label: "Fireship · React Server Components", videoID: "Tn6-PIqc4UM" },
  { label: "Veritasium · The science of thinking", videoID: "UBVV8pch1dM" },
];
---

<section class="px-6 py-16 md:py-24">
  <div class="mx-auto max-w-3xl text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-soft)] px-3 py-1 text-xs text-[var(--color-fg-muted)]">
      <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--color-accent)]"></span>
      {t.badge}
    </span>

    <h1 class="mt-6 text-balance font-[var(--font-display)] text-4xl font-semibold tracking-tight md:text-6xl">
      {t.h1}
    </h1>

    <p class="mx-auto mt-4 max-w-xl text-balance text-base text-[var(--color-fg-muted)] md:text-lg">
      {t.sub}
    </p>

    <form
      id="paste-form"
      method="get"
      action={watchPath}
      class="mx-auto mt-10 flex w-full max-w-2xl flex-col gap-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-soft)] p-3 md:flex-row md:items-stretch"
    >
      <input
        id="paste-input"
        name="v"
        type="text"
        required
        autocomplete="off"
        spellcheck="false"
        placeholder={t.placeholder}
        class="min-w-0 flex-1 rounded-md bg-transparent px-3 py-3 text-base text-[var(--color-fg)] placeholder:text-[var(--color-fg-muted)] focus:outline-none"
      />
      <select
        name="lang"
        class="rounded-md border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-3 text-sm text-[var(--color-fg)]"
      >
        <option value="pl" selected={defaultTarget === "pl"}>{t.targetPl}</option>
        <option value="en" selected={defaultTarget === "en"}>{t.targetEn}</option>
      </select>
      <button
        type="submit"
        class="rounded-md bg-[var(--color-accent)] px-5 py-3 font-medium text-[#0a0a0b] hover:opacity-90"
      >
        {t.cta}
      </button>
    </form>

    <p id="paste-error" class="mt-3 hidden text-sm text-red-400">{t.invalid}</p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-2 text-xs text-[var(--color-fg-muted)]">
      <span>{t.examples}</span>
      {examples.map((ex) => (
        <a
          href={`${watchPath}?v=${ex.videoID}&lang=${defaultTarget}`}
          class="rounded border border-[var(--color-border)] bg-[var(--color-bg-soft)] px-3 py-1 hover:text-[var(--color-fg)]"
        >
          {ex.label}
        </a>
      ))}
    </div>

    <p class="mt-8 text-xs text-[var(--color-fg-muted)]">{t.note}</p>
  </div>
</section>

<script>
  import { parseVideoId } from "@/lib/cues";

  const form = document.getElementById("paste-form") as HTMLFormElement | null;
  const input = document.getElementById("paste-input") as HTMLInputElement | null;
  const error = document.getElementById("paste-error") as HTMLParagraphElement | null;
  if (form && input && error) {
    form.addEventListener("submit", (e) => {
      const id = parseVideoId(input.value);
      if (!id) {
        e.preventDefault();
        error.classList.remove("hidden");
        input.focus();
        return;
      }
      // Replace raw URL with the parsed videoID before submit
      input.value = id;
      error.classList.add("hidden");
    });
  }
</script>
